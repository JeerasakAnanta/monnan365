# Supabase (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key — server-only, used by scripts/seed.mjs to seed data.
# Get it from Supabase Dashboard > Project Settings > API. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — server-only, used by /api/plan.
ANTHROPIC_API_KEY=

# Docker/VPS deployment only: which built image docker-compose should run.
# Leave unset for local `docker compose build`; set to the GitLab registry
# image (e.g. registry.gitlab.com/<group>/<project>:latest) on the VPS.
IMAGE_NAME=
